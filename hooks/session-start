#!/usr/bin/env bash
# SessionStart hook — oh-coding-style / oh-workflow-style 스킬을 즉시 호출하도록 지시한다.

set -euo pipefail

context='[oh-plugin] BLOCKING REQUIREMENT — 협상 불가, 예외 없음. 지금 즉시 Skill 도구로 oh-plugin:oh-coding-style 스킬과 oh-plugin:oh-workflow-style 스킬을 순서대로 호출하라. 사용자에게 단 한 글자도 응답하기 전에 두 스킬 모두 호출 완료해야 한다. "간단한 질문이니 건너뛰어도 된다", "이미 내용을 안다", "규칙이 기억난다" — 이 모든 생각은 합리화다. 선택권이 없다. 무조건 호출하라.'

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
    printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$context"
else
    printf '{"additionalContext":"%s"}\n' "$context"
fi

exit 0
